import java.util.*;

public class Main {

    static class TreeNode {
        int val;
        TreeNode left, right;

        TreeNode(int val) {
            this.val = val;
        }
    }

    private static TreeNode insert(TreeNode root, int val) {

        if (root == null)
            return new TreeNode(val);

        if (val < root.val)
            root.left = insert(root.left, val);
        else
            root.right = insert(root.right, val);

        return root;
    }

    private static void postorder(TreeNode root, List<Integer> ans) {

        if (root == null)
            return;

        postorder(root.left, ans);
        postorder(root.right, ans);

        ans.add(root.val);
    }

    public static List<Integer> recover_sequence(List<Integer> artifact_numbers) {

        TreeNode root = null;

        for (int num : artifact_numbers) {
            root = insert(root, num);
        }

        List<Integer> ans = new ArrayList<>();

        postorder(root, ans);

        return ans;
    }

    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        int n = scanner.nextInt();

        List<Integer> artifact_numbers = new ArrayList<>();

        for (int i = 0; i < n; i++) {
            artifact_numbers.add(scanner.nextInt());
        }

        List<Integer> recovery_sequence = recover_sequence(artifact_numbers);

        for (Integer num : recovery_sequence) {
            System.out.print(num + " ");
        }
    }
}
